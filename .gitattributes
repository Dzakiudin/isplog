# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.db binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
